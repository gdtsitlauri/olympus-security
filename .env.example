# OLYMPUS Environment Configuration
# Copy to .env and adjust values

# GPU settings
OLYMPUS_GPU=1                    # 1=enable CUDA, 0=CPU only
OLYMPUS_DEVICE=cuda              # "cuda" or "cpu"

# API settings
OLYMPUS_API_PORT=8000
OLYMPUS_DASHBOARD_PORT=8501

# Paths (default: relative to project root)
# OLYMPUS_DATA_DIR=/path/to/data
# OLYMPUS_RESULTS_DIR=/path/to/results
